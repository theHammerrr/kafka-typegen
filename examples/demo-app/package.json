{
  "name": "kafka-typegen-demo-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm typecheck",
    "demo": "pnpm --dir ../.. build && pnpm install --force && pnpm generate && pnpm typecheck",
    "generate": "kafka-typegen generate --config ./kafka-typegen.config.mjs",
    "sync:plan": "kafka-typegen sync --config ./kafka-typegen.config.mjs",
    "sync:apply": "kafka-typegen sync --apply --config ./kafka-typegen.config.mjs",
    "produce": "pnpm exec tsx ./src/producer.ts",
    "consume": "pnpm exec tsx ./src/consumer.ts",
    "typecheck": "pnpm exec tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@platformatic/kafka": "^1.31.0",
    "kafka-typegen": "file:../.."
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
