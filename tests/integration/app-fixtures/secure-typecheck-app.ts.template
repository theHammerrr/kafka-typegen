// Compile-only secure fixture: exercises generated KafkaJS producer/consumer/client
// APIs against authenticated brokers so workspace typecheck catches auth-path regressions.
import { Kafka } from 'kafkajs';
import {
  createKafkaJsRuntimeClient,
  createKafkaJsRuntimeConsumer,
  createKafkaJsRuntimeProducer
} from 'kafka-typegen/runtime/kafkajs';
import {
  createClient,
  createConsumer,
  createProducer,
  type UserCreatedPayload
} from './generated/kafka/index.js';

const kafka = new Kafka({
  brokers: ['{{KAFKA_BROKER}}'],
  clientId: '{{RUN_ID}}-secure-typecheck',
  ssl: false,
  sasl: {
    mechanism: 'scram-sha-256',
    password: '{{KAFKA_PASSWORD}}',
    username: '{{KAFKA_USERNAME}}'
  }
});

const producerClient = kafka.producer();
const consumerClient = kafka.consumer({
  groupId: '{{RUN_ID}}-secure-typecheck-group'
});

const serialization = {
  async deserialize(_metadata: unknown, message: { readonly value?: Uint8Array | null }) {
    return JSON.parse(new TextDecoder().decode(message.value ?? undefined));
  },
  async serialize(_metadata: unknown, payload: unknown) {
    return {
      value: new TextEncoder().encode(JSON.stringify(payload))
    };
  }
};

const client = createClient(createKafkaJsRuntimeClient({
  producer: producerClient,
  consumer: consumerClient,
  serialization
}));
const producer = createProducer(createKafkaJsRuntimeProducer({
  producer: producerClient,
  serialization
}));
const consumer = createConsumer(createKafkaJsRuntimeConsumer({
  consumer: consumerClient,
  serialization
}));

const payload: UserCreatedPayload = {
  email: 'ada@example.com',
  id: 'user-1',
  isAdmin: true
};

void client.producer.connect();
void client.consumer.connect();
void producer.{{USER_EVENTS_PROPERTY}}.userCreated.send(payload, { acks: -1 });
void client.producer.{{USER_EVENTS_PROPERTY}}.userCreated.send(payload);
void consumer.{{USER_EVENTS_PROPERTY}}.userCreated.on(async (message) => {
  message.payload.email;
  message.headers?.['x-kafka-typegen-event'];
}, { fromBeginning: true });
void consumer.run();
void consumer.close();
void producer.disconnect();
