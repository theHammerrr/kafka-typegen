{
  "name": "kafka-typegen",
  "version": "1.0.0",
  "description": "Type-safe Kafka client generation from topic definitions and Avro schemas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theHammerrr/kafka-typegen"
  },
  "type": "module",
  "bin": {
    "kafka-typegen": "./dist/cli.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    },
    "./runtime/advanced": {
      "types": "./dist/runtime/advanced.d.ts",
      "import": "./dist/runtime/advanced.js",
      "require": "./dist/runtime/advanced.cjs"
    },
    "./runtime/kafkajs": {
      "types": "./dist/runtime/kafkajs.d.ts",
      "import": "./dist/runtime/kafkajs.js",
      "require": "./dist/runtime/kafkajs.cjs"
    },
    "./runtime/platformatic": {
      "types": "./dist/runtime/platformatic.d.ts",
      "import": "./dist/runtime/platformatic.js",
      "require": "./dist/runtime/platformatic.cjs"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "peerDependencies": {
    "@platformatic/kafka": "^1.31.0"
  },
  "peerDependenciesMeta": {
    "@platformatic/kafka": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "pnpm build && vitest run --config vitest.integration.config.ts",
    "test:integration:secure": "pnpm build && vitest run --config vitest.integration.secure.config.ts",
    "test:performance": "vitest run tests/performance.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "powershell -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\""
  },
  "devDependencies": {
    "@platformatic/kafka": "1.31.0",
    "@testcontainers/kafka": "^11.13.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "testcontainers": "^11.13.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "avsc": "^5.7.9",
    "kafkajs": "^2.2.4",
    "zod": "^4.3.6"
  }
}
